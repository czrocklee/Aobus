{
  "version": 8,
  "configurePresets": [
    {
      "name": "linux-debug",
      "generator": "Unix Makefiles",
      "binaryDir": "/tmp/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-release",
      "generator": "Unix Makefiles",
      "binaryDir": "/tmp/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "linux-pgo-profile",
      "generator": "Unix Makefiles",
      "binaryDir": "/tmp/pgo-build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_FLAGS": "-fprofile-generate -fprofile-arcs -O2 -g -fno-omit-frame-pointer -Wno-error",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-arcs"
      }
    },
    {
      "name": "linux-pgo-optimize",
      "generator": "Unix Makefiles",
      "binaryDir": "/tmp/pgo-build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CXX_FLAGS": "-fprofile-use -fprofile-correction -O3 -g -fno-omit-frame-pointer -Wno-error",
        "CMAKE_EXE_LINKER_FLAGS": "-fprofile-use"
      }
    },
    {
      "name": "profile",
      "generator": "Unix Makefiles",
      "binaryDir": "/tmp/profile",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-fno-omit-frame-pointer",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-tui-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "AOBUS_BUILD_CLI": "OFF",
        "AOBUS_BUILD_GTK": "OFF",
        "AOBUS_BUILD_TESTS": "OFF",
        "AOBUS_BUILD_TOOLS": "OFF",
        "AOBUS_BUILD_TUI": "ON"
      }
    },
    {
      "name": "windows-tui-debug",
      "inherits": "windows-tui-base",
      "binaryDir": "out/build/windows-tui-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-tui-debug-tests",
      "inherits": "windows-tui-debug",
      "binaryDir": "out/build/windows-tui-debug-tests",
      "cacheVariables": {
        "AOBUS_BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "windows-tidy",
      "inherits": "windows-tui-release-tests",
      "binaryDir": "out/build/windows-tidy",
      "cacheVariables": {
        "AOBUS_BUILD_LINT_PLUGIN": "ON",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "windows-tui-release",
      "inherits": "windows-tui-base",
      "binaryDir": "out/build/windows-tui-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-tui-release-tests",
      "inherits": "windows-tui-release",
      "binaryDir": "out/build/windows-tui-release-tests",
      "cacheVariables": {
        "AOBUS_BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    }
  ]
}
