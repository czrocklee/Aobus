<Window
    x:Class="Aobus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Aobus"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Border
            MaxWidth="640"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <StackPanel Spacing="16">
                <TextBlock
                    FontSize="32"
                    Style="{ThemeResource TitleTextBlockStyle}"
                    Text="Aobus for Windows" />
                <TextBlock
                    Text="The WinUI 3 frontend is running from Aobus' CMake and MSBuild pipeline."
                    TextWrapping="Wrap" />
                <Button
                    HorizontalAlignment="Left"
                    Click="OnVerifyClicked"
                    Content="Verify WinUI" />
                <TextBlock
                    x:Name="StatusText"
                    Text="XAML resources loaded successfully." />
            </StackPanel>
        </Border>
    </Grid>
</Window>
