# Clang-tidy configuration for RockStudio
# Single source of truth for checks

Checks: '-*,readability-include-declaration,modernize-use-nullptr,modernize-use-std-arrays,modernize-raw-string-literal,modernize-use-std-numbers,modernize-loop-convert,modernize-use-emplace,modernize-use-nodiscard,modernize-use-requires,modernize-use-final,cppcoreguidelines-avoid-goto,performance-move-const-arg,performance-unnecessary-copy,performance-unnecessary-value-param,performance-noexcept,performance-type-promotion,bugprone-assert-side-effect,bugprone-branch-clone,bugprone-unused-local-non-trivial-type,bugprone-reserved-identifier,hicpp-vararg,readability-const-return-type,readability-redundant-string-init,readability-function-size,readability-magic-numbers'

# Check options
CheckOptions:
  # Include sorting - group by priority (main project, then third-party, then std)
  - key: readability-include-declaration.IncludeBlocks
    value: 'Regroup'

  # Performance: prefer emplace over push_back
  - key: modernize-use-emplace.MergeSmallTypes
    value: '1'

  # Function size warning threshold
  - key: readability-function-size.StatementThreshold
    value: '60'

  # Magic numbers: allow common constants
  - key: readability-magic-numbers.IgnoreBitFields
    value: '1'
  - key: readability-magic-numbers.IgnorePODAnnotations
    value: '1'
  - key: readability-magic-numbers.IgnoredNumbers
    value: '5'
