#!/usr/bin/env bash
# script/agent/validation.env — Aobus agent-fleet validation ALLOWLIST.
#
# A phase's validation must be an ID from this file, never an arbitrary shell string carried in a
# packet. A packet may be authored by a cheap model or a dispatcher; an arbitrary command would be an
# injection vector. Each allowed validation is a function `v_<id>`; the harness (agent_validate in
# common.sh) resolves the ID, passes sanitized repo-relative args as quoted positionals (never via
# eval), and runs it from the repo root. Exit 0 = pass, nonzero = fail.
#
# To add a validation: add a `v_<id>` function here. That is the ONLY place a new command becomes
# reachable from a packet. Override the whole table for tests via AOBUS_VALIDATION_ENV.

# tidy [<file>...] — clang-tidy gate: pass iff run-clang-tidy.sh reports zero warnings/errors.
# This is exactly the gate the C1 lint phase converges to; the dispatcher re-runs it independently.
v_tidy() {
  local out rc n
  out="$(./script/run-clang-tidy.sh "$@" 2>&1)"; rc=$?
  if [ "$rc" -ne 0 ]; then
    printf '%s\n' "$out" >&2
    return "$rc"
  fi
  n="$(printf '%s\n' "$out" | rg -c 'warning:|error:' || true)"
  [ "${n:-0}" -eq 0 ]
}

# build-debug — standard debug build + test gate.
v_build_debug() { ./build.sh debug; }

# test-core <catch2-filter> — core tests matching a Catch2 tag expression (e.g. [audio]).
v_test_core() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --core "$1"; }
v_test_core_list() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --core --list "$1"; }

# test-gtk <catch2-filter> — GTK tests matching a Catch2 tag expression (e.g. [layout],[model]).
v_test_gtk() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --gtk "$1"; }
v_test_gtk_list() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --gtk --list "$1"; }

# test-all — build + run the WHOLE core AND GTK suites (no Catch2 filter). This is the SINGLE oracle the
# C2 proposal executor uses: the executor no longer selects a test subset from the changed paths (the
# whole suite runs in seconds and any change ultimately reaches the app, so a blast-radius gate bought
# complexity, not safety). Builds ao_test + ao_test_gtk + aobus-gtk, then runs both test binaries;
# honours the pre-configured BUILD_DIR. The GTK suite runs headless (the tests realize no widget and
# load no preset), so no DISPLAY/xvfb is needed. HONESTY: a green run proves the change is compile/link
# coherent across the WHOLE tree and that EVERY existing test still passes -- NOT that behavior on
# untested paths is unchanged. C3 still judges semantics; the dossier carries the residual.
v_test_all() {
  local b="${BUILD_DIR:?test-all needs BUILD_DIR}"
  cmake --build "$b" --parallel --target ao_test ao_test_gtk aobus-gtk \
    || { echo "test-all: build failed" >&2; return 1; }
  "$b/test/ao_test" || return 1
  "$b/test/ao_test_gtk"
}

# test-core-all — build + run the WHOLE core suite (no Catch2 filter). Builds only ao_test (run-tests.sh
# would also build the heavy GTK target); honours the pre-configured BUILD_DIR. A green run proves the
# change is compile/link-coherent across the core tree and the EXISTING core tests pass -- not that
# behavior on untested paths is unchanged.
v_test_core_all() {
  local b="${BUILD_DIR:?test-core-all needs BUILD_DIR}"
  cmake --build "$b" --parallel --target ao_test \
    || { echo "test-core-all: core build failed" >&2; return 1; }
  "$b/test/ao_test"
}

# test-gtk-all — build + run the WHOLE GTK test suite (no Catch2 filter). The GTK tests run headless (no
# widget realization, no preset), so no DISPLAY/xvfb is needed.
v_test_gtk_all() {
  local b="${BUILD_DIR:?test-gtk-all needs BUILD_DIR}"
  cmake --build "$b" --parallel --target ao_test_gtk aobus-gtk \
    || { echo "test-gtk-all: GTK build failed" >&2; return 1; }
  "$b/test/ao_test_gtk"
}

# test-core-asan / test-core-tsan <catch2-filter> — sanitizer oracles. These are a GENUINELY new gate:
# agent_validate_in_repo pre-configures BUILD_DIR with `cmake --preset linux-debug`, which leaves
# AOBUS_ENABLE_ASAN/TSAN OFF (cmake/CompilerOptions.cmake), so plain test-core runs with no sanitizer.
# Each id configures its OWN sub-build-dir with the sanitizer option on, builds ONLY the core ao_test
# target (run-tests.sh would also build the heavy GTK target — wrong for a "core" gate and ASan-noisy),
# then runs the core binary with the Catch2 filter. A sanitizer finding aborts the process -> nonzero
# -> the gate fails. HONESTY: a clean run means "no ASan/UBSan/TSan finding on the EXERCISED paths",
# not "memory-/race-safe". ASan and TSan are mutually exclusive, hence two ids / two build dirs.
v_test_core_asan() {
  local b="${BUILD_DIR:?test-core-asan needs BUILD_DIR}/asan"
  cmake --preset linux-debug -B "$b" -DAOBUS_ENABLE_ASAN=ON >/dev/null 2>&1 \
    || { echo "test-core-asan: ASan configure failed" >&2; return 1; }
  cmake --build "$b" --parallel --target ao_test \
    || { echo "test-core-asan: ASan build failed" >&2; return 1; }
  ASAN_OPTIONS="${ASAN_OPTIONS:-halt_on_error=1:abort_on_error=1:detect_leaks=1}" \
  UBSAN_OPTIONS="${UBSAN_OPTIONS:-halt_on_error=1:print_stacktrace=1}" \
    "$b/test/ao_test" "$1"
}
v_test_core_tsan() {
  local b="${BUILD_DIR:?test-core-tsan needs BUILD_DIR}/tsan"
  cmake --preset linux-debug -B "$b" -DAOBUS_ENABLE_TSAN=ON >/dev/null 2>&1 \
    || { echo "test-core-tsan: TSan configure failed" >&2; return 1; }
  cmake --build "$b" --parallel --target ao_test \
    || { echo "test-core-tsan: TSan build failed" >&2; return 1; }
  TSAN_OPTIONS="${TSAN_OPTIONS:-halt_on_error=1}" "$b/test/ao_test" "$1"
}

# Per-validation arg contract: "<type> <min> <max>" (max '-' = unbounded). Enforced deterministically by
# agent_validation_args_ok (common.sh) BEFORE the validation runs, so a packet that puts the wrong KIND or
# COUNT of args on a validation — a Catch2 filter where tidy wants files, a file where a test filter is
# wanted, too many or too few — is rejected up front, not after a slow build. Keep one row per v_<id>
# above; <type> resolves through agent_argtype_re (path | filter | any | ...).
# -gA (global): this file is sourced from inside agent_load_validation(), and a bare `declare` inside a
# function is function-local — it would vanish on return. -g keeps the table reachable by the runner.
declare -gA VALIDATION_ARGSPEC=(
  [tidy]="path 1 -"             # one or more repo-relative source paths
  [build-debug]="any 0 -"       # ignores its args (build.sh debug); tolerate a runner's input list
  [test-core]="filter 1 1"      # exactly one Catch2 tag expression, e.g. [audio]
  [test-all]="any 0 -"          # no filter: the whole core + GTK suite (the single C2 proposal oracle)
  [test-core-all]="any 0 -"     # no filter: the whole core suite
  [test-gtk-all]="any 0 -"      # no filter: the whole GTK suite
  [test-gtk]="filter 1 1"       # exactly one Catch2 tag expression, e.g. [layout],[model]
  [test-core-asan]="filter 1 1" # one Catch2 tag expression, built+run under ASan/UBSan
  [test-core-tsan]="filter 1 1" # one Catch2 tag expression, built+run under TSan
)

declare -gA VALIDATION_IS_ISOLATABLE=(
  [tidy]="1"
  [build-debug]="1"
  [test-core]="1"
  [test-all]="1"
  [test-core-all]="1"
  [test-gtk-all]="1"
  [test-gtk]="1"
  [test-core-asan]="1"
  [test-core-tsan]="1"
)
