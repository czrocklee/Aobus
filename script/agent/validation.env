#!/usr/bin/env bash
# script/agent/validation.env — Aobus agent-fleet validation ALLOWLIST.
#
# A phase's validation must be an ID from this file, never an arbitrary shell string carried in a
# packet. A packet may be authored by a cheap model or a dispatcher; an arbitrary command would be an
# injection vector. Each allowed validation is a function `v_<id>`; the harness (agent_validate in
# common.sh) resolves the ID, passes sanitized repo-relative args as quoted positionals (never via
# eval), and runs it from the repo root. Exit 0 = pass, nonzero = fail.
#
# To add a validation: add a `v_<id>` function here. That is the ONLY place a new command becomes
# reachable from a packet. Override the whole table for tests via AOBUS_VALIDATION_ENV.

# tidy [<file>...] — clang-tidy gate: pass iff run-clang-tidy.sh reports zero warnings/errors.
# This is exactly the gate the C1 lint phase converges to; the dispatcher re-runs it independently.
v_tidy() {
  local out rc n
  out="$(./script/run-clang-tidy.sh "$@" 2>&1)"; rc=$?
  if [ "$rc" -ne 0 ]; then
    printf '%s\n' "$out" >&2
    return "$rc"
  fi
  n="$(printf '%s\n' "$out" | rg -c 'warning:|error:' || true)"
  [ "${n:-0}" -eq 0 ]
}

# build-debug — standard debug build + test gate.
v_build_debug() { ./build.sh debug; }

# test-core <catch2-filter> — core tests matching a Catch2 tag expression (e.g. [audio]).
v_test_core() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --core "$1"; }
v_test_core_list() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --core --list "$1"; }

# test-gtk <catch2-filter> — GTK tests matching a Catch2 tag expression (e.g. [layout],[model]).
v_test_gtk() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --gtk "$1"; }
v_test_gtk_list() { ./script/run-tests.sh ${BUILD_DIR:+--path "$BUILD_DIR"} --gtk --list "$1"; }

# Per-validation arg contract: "<type> <min> <max>" (max '-' = unbounded). Enforced deterministically by
# agent_validation_args_ok (common.sh) BEFORE the validation runs, so a packet that puts the wrong KIND or
# COUNT of args on a validation — a Catch2 filter where tidy wants files, a file where a test filter is
# wanted, too many or too few — is rejected up front, not after a slow build. Keep one row per v_<id>
# above; <type> resolves through agent_argtype_re (path | filter | any | ...).
# -gA (global): this file is sourced from inside agent_load_validation(), and a bare `declare` inside a
# function is function-local — it would vanish on return. -g keeps the table reachable by the runner.
declare -gA VALIDATION_ARGSPEC=(
  [tidy]="path 1 -"          # one or more repo-relative source paths
  [build-debug]="any 0 -"    # ignores its args (build.sh debug); tolerate a runner's input list
  [test-core]="filter 1 1"   # exactly one Catch2 tag expression, e.g. [audio]
  [test-gtk]="filter 1 1"    # exactly one Catch2 tag expression, e.g. [layout],[model]
)

declare -gA VALIDATION_IS_ISOLATABLE=(
  [test-core]="1"
  [test-gtk]="1"
)
