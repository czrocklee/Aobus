#!/usr/bin/env bash
# script/agent/validation.env — Aobus agent-fleet validation ALLOWLIST.
#
# A phase's validation must be an ID from this file, never an arbitrary shell string carried in a
# packet. A packet may be authored by a cheap model or a dispatcher; an arbitrary command would be an
# injection vector. Each allowed validation is a function `v_<id>`; the harness (agent_validate in
# common.sh) resolves the ID, passes sanitized repo-relative args as quoted positionals (never via
# eval), and runs it from the repo root. Exit 0 = pass, nonzero = fail.
#
# To add a validation: add a `v_<id>` function here. That is the ONLY place a new command becomes
# reachable from a packet. Override the whole table for tests via AOBUS_VALIDATION_ENV.

# tidy [<file>...] — clang-tidy gate: pass iff run-clang-tidy.sh reports zero warnings/errors.
# This is exactly the gate the C1 lint phase converges to; the dispatcher re-runs it independently.
v_tidy() {
  local n
  n="$(./script/run-clang-tidy.sh "$@" 2>/dev/null | rg -c 'warning:|error:' || true)"
  [ "${n:-0}" -eq 0 ]
}

# build-debug — standard debug build + test gate.
v_build_debug() { ./build.sh debug; }

# test-core <catch2-filter> — core tests matching a Catch2 tag expression (e.g. [audio]).
v_test_core() { ./script/run-tests.sh --core "$1"; }

# test-gtk <catch2-filter> — GTK tests matching a Catch2 tag expression (e.g. [layout],[model]).
v_test_gtk() { ./script/run-tests.sh --gtk "$1"; }
