#!/usr/bin/env bash
# script/agent/routing.env — Aobus agent-fleet capability -> executor routing table.
#
# This is §4 of doc/design/agent-fleet-tiering.md made executable: THE single file to edit when the
# fleet changes. Phase runners source this and never hardcode a model. Skills and the phase
# contracts stay untouched across a model swap.
#
# Worker contract (per capability class):
#   - The runner exports AGENT_SANDBOX (an isolated, non-repo cwd holding only a copy of the target
#     at its repo-relative path), AGENT_REL (that repo-relative path), and AGENT_PROMPT (the task).
#     It then calls route_<class>_worker.
#   - The worker MUST run its model NON-INTERACTIVELY with cwd = AGENT_SANDBOX, editing only the
#     target copy. It returns when done; the runner takes the patch by diffing AGENT_SANDBOX/AGENT_REL
#     (harness-diff). A worker may re-stage elsewhere as long as the edit lands back at that path.
#   - WORKER_TIMEOUT (seconds) bounds the call.
#
# Override for testing or a local fleet: point AOBUS_ROUTING_ENV at an alternate file; runners load
# that instead. (A mock routing.env that swaps only route_c1_worker is the standard test seam.)

# --- C1: bounded, mechanical work with a deterministic gate (lint fixes, scaffolding). ---
# Cheap + fast; the validation gate and guards make a weaker model safe here.
route_c1_worker() {
  ( cd "$AGENT_SANDBOX" && timeout "${WORKER_TIMEOUT:-240}" \
      opencode run -m "opencode-go/deepseek-v4-flash" "$AGENT_PROMPT" ) </dev/null
}

# Second C1 candidate (a stronger fast model). C1's multi-candidate form is NOT "primary, then fall
# back on failure" — it is "fan out several cheap candidates in parallel, then validate only the best"
# (§4). Candidate token cost is near-free; the expensive parts are slow validation and C3 review, so
# the runner guards + ranks the patches deterministically and validates at most top-K (§5.1). Fan-out
# is opt-in (see ROUTE_C1_CANDIDATES below); add this worker to the set to enable it.
route_c1_worker_pro() {
  ( cd "$AGENT_SANDBOX" && timeout "${WORKER_TIMEOUT:-300}" \
      opencode run -m "opencode-go/deepseek-v4-pro" "$AGENT_PROMPT" ) </dev/null
}

# Shared agy invocation behind the steam-run isolation workaround — used by EVERY agy-backed worker
# (the C1 Gemini Flash candidate and the C2 Gemini Pro alternate). Three adaptations vs the opencode
# workers, all established by the Step A probe + isolation diagnostic (§9):
#   1. agy edits files agentically in `-p` mode and keeps its narration on STDOUT, never in the file
#      (the old `gemini -p` "narration pollutes the file" failure is gone).
#   2. steam-run gives agy a PRIVATE /tmp, so an AGENT_SANDBOX under /tmp is invisible to it. Stage the
#      target under $HOME (bind-mounted into steam-run), run agy there, copy the edit back.
#   3. ISOLATION (important): steam-run bind-mounts ALL of $HOME, so the real repo is reachable. agy was
#      observed to "escape" to the real file when the staged path matched a real git-repo-relative path
#      (it preferred the actual project over the cwd copy). Mitigation: stage the single target at a
#      sandbox-unique FLAT name with no repo-path collision, and rewrite the prompt to name THAT file.
#      A repo canary confirmed the real tree stays untouched under this scheme. This is path-collision
#      avoidance for a TRUSTED vendor model, NOT a hard sandbox (see §10.3); every edit is still gated by
#      harness-diff + deterministic guard + independent re-validation, so a stray edit cannot silently land.
# $1 = agy --model string. Needs the worker-contract vars AGENT_SANDBOX / AGENT_REL / AGENT_PROMPT.
_route_agy_edit() {
  local model="$1"
  local rel="${AGENT_REL:?_route_agy_edit needs AGENT_REL}"
  local stageroot="${AOBUS_AGY_STAGE:-$HOME/.cache/aobus-agy}"; mkdir -p "$stageroot"
  local stage; stage="$(mktemp -d "$stageroot/sbx.XXXXXX")" || return 1
  local flat="sbx_$$_$(basename "$rel")"          # unique cwd-relative name: cannot collide with the repo
  cp "$AGENT_SANDBOX/$rel" "$stage/$flat"
  local prompt="${AGENT_PROMPT//$rel/$flat}"      # make the prompt name the flat file, not the repo path
  ( cd "$stage" && timeout "${WORKER_TIMEOUT:-300}" \
      steam-run agy -p "$prompt" --model "$model" \
        --add-dir "$stage" --dangerously-skip-permissions ) </dev/null
  local rc=$?
  cp "$stage/$flat" "$AGENT_SANDBOX/$rel"         # land the edit back at the path the runner diffs
  rm -rf "$stage"
  return "$rc"
}

# Cross-vendor C1 candidate: Google Gemini Flash via agy. AGY_MODEL overrides the model id.
route_c1_worker_gflash() { _route_agy_edit "${AGY_MODEL:-Gemini 3.5 Flash (Low)}"; }

# The C1 candidate set the lint phase fans out (in parallel) for each fix round. The DEFAULT is the
# single cheapest worker (DeepSeek Flash via opencode): zero fan-out, lowest latency, no steam-run/agy
# spin-up, and none of the agy soft-isolation caveat. Multi-candidate fan-out is OPT-IN — add a second
# source to trade extra (near-free) candidate generation for a higher fix-on-first-round rate; the
# runner still validates only the deterministically-ranked top-K, so more candidates never cost more
# than MAX_VALIDATE slow runs. To opt in to the CROSS-VENDOR mix (a genuine second source so the
# fan-out is not single-vendor), uncomment the cross-vendor line below; or use route_c1_worker_pro for
# a stronger same-vendor mix. Runners that source an older routing.env without this array fall back to
# (route_c1_worker), so the single-worker default stays backward compatible.
ROUTE_C1_CANDIDATES=(route_c1_worker)
# ROUTE_C1_CANDIDATES=(route_c1_worker route_c1_worker_gflash)   # opt-in: cross-vendor (adds agy/Gemini)
# ROUTE_C1_CANDIDATES=(route_c1_worker route_c1_worker_pro)      # opt-in: stronger same-vendor mix

# Human-readable labels for the C1 candidate functions — the multi-candidate analogue of ROUTE_C2_LABEL,
# used by lint_phase's fan-out log so a round reads as model names, not function ids. Keyed by worker
# function name; a candidate with no entry falls back to its function name. Add an entry per route_c1_*
# worker above. (A mock routing.env that omits this map still works: the runner uses the fallback.)
# -gA (global): this file is sourced from inside agent_load_routing(); a bare `declare` would be
# function-local and lost on return, so the runner could never read the labels back.
declare -gA ROUTE_C1_LABELS=(
  [route_c1_worker]="DeepSeek V4 Flash via opencode"
  [route_c1_worker_pro]="DeepSeek V4 Pro via opencode"
  [route_c1_worker_gflash]="Gemini 3.5 Flash via agy"
)

# --- C2: scoped implementation inside a fixed design (wired into test_phase.sh). Unlike C1 (a fan-out
#         candidate SET), C2 runs a SINGLE active worker with error-feedback rounds, so the fleet picks
#         one via the ROUTE_C2_WORKER selector below; alternates are declared and swapped in by a
#         one-line toggle (the C2 analogue of C1's opt-in candidate lines). ---
# Default C2 worker: GPT-5.5 via codex. --skip-git-repo-check: the sandbox is a throwaway non-git cwd.
route_c2_worker() {
  ( cd "$AGENT_SANDBOX" && timeout "${WORKER_TIMEOUT:-600}" \
      codex exec -s workspace-write --skip-git-repo-check "$AGENT_PROMPT" ) </dev/null
}

# Cross-vendor C2 alternate: Gemini 3.1 Pro (high reasoning) via agy. AGY_C2_MODEL overrides the model.
route_c2_worker_gpro() { _route_agy_edit "${AGY_C2_MODEL:-Gemini 3.1 Pro (High)}"; }

# The active C2 worker + its label (the runner calls "$ROUTE_C2_WORKER" and reports ROUTE_C2_LABEL).
# Swap to the alternate by uncommenting the second pair. A routing.env without ROUTE_C2_WORKER still
# works: the runner falls back to route_c2_worker.
ROUTE_C2_WORKER="route_c2_worker";      ROUTE_C2_LABEL="GPT-5.5 via codex"
# ROUTE_C2_WORKER="route_c2_worker_gpro"; ROUTE_C2_LABEL="Gemini 3.1 Pro (high) via agy"

# --- C3: frontier reasoning (plan / diagnose / review / error-contract choices). The PRIMARY chair is
#         the current in-loop agent. Its identity is implicit and managed by the conversational context,
#         not the routing environment. The COUNCIL form (council.sh, §11) additionally convenes the
#         roster below as read-only committee members that draft → challenge → revise, so the chair can
#         verify and synthesize from a debated dossier. C3 is still never auto-dispatched by a cheap
#         runner; the chair convenes a council deliberately, only for high-stakes plan/review. ---

# C3 council MEMBER contract (used by council.sh, the C0 orchestrator):
#   in:  AGENT_COUNCIL_PROMPT_FILE (a file holding the round's role + task), AGENT_COUNCIL_CWD (a
#        disposable READ-ONLY repo copy to run in), AGENT_COUNCIL_OUT (an out dir OUTSIDE the repo),
#        AGENT_COUNCIL_SLOT (the file under AGENT_COUNCIL_OUT to write this member's opinion to).
#   out: the member runs in AGENT_COUNCIL_CWD and writes its prose opinion to
#        $AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT (its stdout). It MUST NOT mutate the tree — council.sh
#        gives each member its own copy and a before/after content canary (modes + symlink targets +
#        content), discarding + flagging any member that wrote a file (§11). AGENT_COUNCIL_CWD defaults
#        to AGENT_REPO if the orchestrator did not stage a copy.
#   The prompt is fed on STDIN from AGENT_COUNCIL_PROMPT_FILE, NOT as an argv string: a high-stakes
#   review body carries a large diff and a single CLI argument is capped at ~128KB (Linux
#   MAX_ARG_STRLEN); stdin has no such limit. The opinion IS the model's stdout; stderr is kept beside it
#   as .err. COUNCIL_TIMEOUT (seconds) bounds each call. The runner ALSO requires a zero exit status, so
#   a timed-out/crashed member that left partial output is not seated.
# Unlike C1/C2 (sandbox-copy editors), a member is fundamentally different: it produces an OPINION, not
# a patch, and never touches the tree — hence no _route_agy_edit staging here; native read-only CLIs.
# Both Claude and DeepSeek use --dangerously-skip-permissions to enable headless, non-interactive
# operation; the orchestrator's tree-immutability canary is the real backstop for source safety.
route_c3_member_claude_opus() {
  ( cd "${AGENT_COUNCIL_CWD:-$AGENT_REPO}" && timeout "${COUNCIL_TIMEOUT:-900}" \
      claude -p --dangerously-skip-permissions --no-session-persistence \
      --model "${CLAUDE_C3_MODEL:-opus}" --effort "${CLAUDE_C3_EFFORT:-xhigh}" ) \
    < "$AGENT_COUNCIL_PROMPT_FILE" \
    > "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT" 2> "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT.err"
}
route_c3_member_codex() {
  ( cd "${AGENT_COUNCIL_CWD:-$AGENT_REPO}" && timeout "${COUNCIL_TIMEOUT:-900}" \
      codex exec -s read-only --skip-git-repo-check \
      --model "${CODEX_C3_MODEL:-gpt-5.5}" \
      -c "model_reasoning_effort=\"${CODEX_C3_EFFORT:-high}\"" ) \
    < "$AGENT_COUNCIL_PROMPT_FILE" \
    > "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT" 2> "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT.err"
}
# agy `--print` mode is read-only when used without `--dangerously-skip-permissions` (or even with it,
# the canary protects the tree). We use steam-run for agy isolation as described at the top of this file.
# The prompt is read from stdin (with an empty -p, agy uses stdin as the prompt).
# GEMINI_C3_MODEL overrides the model id.
route_c3_member_gemini() {
  ( cd "${AGENT_COUNCIL_CWD:-$AGENT_REPO}" && timeout "${COUNCIL_TIMEOUT:-900}" \
      steam-run agy -p "" --dangerously-skip-permissions --model "${GEMINI_C3_MODEL:-Gemini 3.1 Pro (High)}" ) \
    < "$AGENT_COUNCIL_PROMPT_FILE" \
    > "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT" 2> "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT.err"
}
# opencode `run` uses --dangerously-skip-permissions for headless operation. For a council member that
# just answers a read-only review/plan query this is fine; the tree-immutability canary is the real
# backstop, not a vendor flag. Reads the prompt on stdin.
route_c3_member_dspro() {
  ( cd "${AGENT_COUNCIL_CWD:-$AGENT_REPO}" && timeout "${COUNCIL_TIMEOUT:-1200}" \
      opencode run --dangerously-skip-permissions --variant "${DSPRO_C3_VARIANT:-max}" -m "opencode-go/deepseek-v4-pro" ) \
    < "$AGENT_COUNCIL_PROMPT_FILE" \
    > "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT" 2> "$AGENT_COUNCIL_OUT/$AGENT_COUNCIL_SLOT.err"
}

# The committee roster council.sh fans out. The chair = current in-loop agent is NOT in this list and
# does not draft; if the chair's model should contribute an R1/R2/R3 opinion, add it here as an ordinary
# member (as route_c3_member_claude_opus does). Keep at least one different model/vendor in the roster so
# the council has real diversity instead of same-model self-sampling. A runner sourcing an older
# routing.env without this array falls back to the historical cross-vendor trio. -gA on the label map:
# this file is sourced inside agent_load_routing(), so a bare declare would be function-local and lost on
# return.
ROUTE_C3_MEMBERS=(route_c3_member_claude_opus route_c3_member_codex route_c3_member_gemini route_c3_member_dspro)
declare -gA ROUTE_C3_MEMBER_LABELS=(
  [route_c3_member_claude_opus]="Claude Opus via claude"
  [route_c3_member_codex]="GPT-5.5 (high) via codex"
  [route_c3_member_gemini]="Gemini 3 Pro via gemini"
  [route_c3_member_dspro]="DeepSeek V4 Pro via opencode"
)
