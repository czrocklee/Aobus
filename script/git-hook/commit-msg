#!/usr/bin/env python3
import sys
import re

def main():
    commit_msg_filepath = sys.argv[1]
    with open(commit_msg_filepath, 'r', encoding='utf-8') as f:
        content = f.read()

    # Look for Co-Authored-By with AI names
    ai_patterns = [r'claude', r'gpt', r'gemini', r'deepseek']
    
    for line in content.splitlines():
        if re.search(r'co-authored-by:', line, re.IGNORECASE):
            if any(re.search(pat, line, re.IGNORECASE) for pat in ai_patterns):
                print("\n" + "=" * 80)
                print("❌ [Git Hook ERROR] Commit blocked: AI co-author attribution detected!")
                print("-" * 80)
                print("  Warning: Explicit instructions forbid AI co-author signatures.")
                print("  Please remove the Co-Authored-By line for Claude/GPT/Gemini/DeepSeek.")
                print("=" * 80 + "\n")
                sys.exit(1)

if __name__ == '__main__':
    main()
