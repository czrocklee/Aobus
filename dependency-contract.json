{
  "schemaVersion": 2,
  "leadResolver": "nix",
  "dependencies": {
    "boost": {
      "platforms": [
        "linux",
        "windows"
      ],
      "policy": {
        "kind": "exact",
        "version": "1.89.0"
      },
      "nix": {
        "attribute": "boost"
      },
      "vcpkg": {
        "strategy": "scoped-registry",
        "ports": [
          "boost-algorithm",
          "boost-asio",
          "boost-container",
          "boost-endian",
          "boost-filesystem",
          "boost-headers",
          "boost-interprocess",
          "boost-lockfree",
          "boost-pfr",
          "boost-process",
          "boost-unordered"
        ]
      },
      "cmake": {
        "package": "Boost",
        "targets": [
          "Boost::headers",
          "Boost::process",
          "Boost::filesystem"
        ]
      }
    },
    "ftxui": {
      "platforms": [
        "linux",
        "windows"
      ],
      "policy": {
        "kind": "exact",
        "version": "6.1.9"
      },
      "nix": {
        "attribute": "ftxui"
      },
      "vcpkg": {
        "strategy": "override",
        "ports": [
          "ftxui"
        ]
      },
      "cmake": {
        "package": "ftxui",
        "requiredWhen": "AOBUS_BUILD_TUI",
        "targets": [
          "ftxui::screen",
          "ftxui::dom",
          "ftxui::component"
        ]
      }
    },
    "spdlog": {
      "platforms": [
        "linux",
        "windows"
      ],
      "policy": {
        "kind": "exact",
        "version": "1.17.0"
      },
      "nix": {
        "attribute": "spdlog"
      },
      "vcpkg": {
        "strategy": "baseline",
        "ports": [
          "spdlog"
        ]
      },
      "cmake": {
        "package": "spdlog",
        "targets": [
          "spdlog::spdlog"
        ]
      },
      "capabilities": [
        "spdlog-std-format",
        "spdlog-no-external-fmt"
      ]
    },
    "windows-app-sdk": {
      "platforms": [
        "windows"
      ],
      "policy": {
        "kind": "exact",
        "version": "2.3.1"
      },
      "nuget": {
        "package": "Microsoft.WindowsAppSDK",
        "lock": "app/windows-winui/packages.config"
      },
      "msbuild": {
        "requiredWhen": "AOBUS_BUILD_WINUI"
      },
      "runtime": {
        "packageName": "Microsoft.WindowsAppRuntime.2",
        "version": "2.3.1.0",
        "architecture": "x64",
        "installerUrl": "https://aka.ms/windowsappsdk/2.3/2.3.1/windowsappruntimeinstall-x64.exe",
        "sha256": "4011748ddf472b7e856d909fdfb4e9b19c3d23fcd8121039ac91f99d5ffa65db"
      }
    },
    "cppwinrt": {
      "platforms": [
        "windows"
      ],
      "policy": {
        "kind": "exact",
        "version": "3.0.260715.1"
      },
      "nuget": {
        "package": "Microsoft.Windows.CppWinRT",
        "lock": "app/windows-winui/packages.config"
      },
      "msbuild": {
        "requiredWhen": "AOBUS_BUILD_WINUI"
      }
    }
  },
  "exceptions": []
}
